[Unit]
Description=Helix Bot Builder Backend (Laravel)
After=network.target

[Service]
Type=simple
User=talinoserver2
WorkingDirectory=/home/talinoserver2/Documents/bot-builder-suite/laravel-backend
ExecStart=/usr/bin/php artisan serve --host=127.0.0.1 --port=8082
Restart=always
RestartSec=10
StandardOutput=append:/home/talinoserver2/Documents/bot-builder-suite/logs/backend.log
StandardError=append:/home/talinoserver2/Documents/bot-builder-suite/logs/backend.error.log

[Install]
WantedBy=multi-user.target
